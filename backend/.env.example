# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/eryo_db

# JWT para autenticación del admin
SECRET_KEY=tu-clave-secreta-aqui-cambiala
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cloudinary (fotos de productos)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Google Apps Script (URL del webhook para correos)
GAS_WEBHOOK_URL=https://script.google.com/macros/s/tu-script-id/exec

# Correo donde recibir notificaciones de nuevos pedidos (vendedor)
VENDEDOR_EMAIL=

# CORS - URL del frontend
FRONTEND_URL=http://localhost:3000
